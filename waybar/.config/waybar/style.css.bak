@import "mocha.css";

/* ─── Reset ──────────────────────────────────────────────────── */
* {
  font-weight: bold;
  font-family: "JetBrainsMono Nerd Font";
  font-size: 16px;
  background-color: transparent;
  color: @text;
  border: none;
  border-radius: 0;
  min-height: 0;
}

/* ─── Outer bar: fully transparent, each module is its own pill ─ */
window#waybar {
  background-color: transparent;
  margin: 0;
  padding: 0;
}

/* No shared section backgrounds — modules handle their own pills */
.modules-left,
.modules-center,
.modules-right {
  background-color: transparent;
  border: none;
  padding: 0;
  margin: 0;
}

/* ─── Shared pill style for all modules ──────────────────────── */
#custom-arch,
#clock,
#custom-media,
#workspaces,
#pulseaudio,
#network,
#battery,
#tray {
  background-color: alpha(@crust, 0.85);
  border: 1px solid alpha(@surface0, 0.9);
  border-radius: 16px;
  margin: 3px 3px 0 3px;
  padding: 2px 12px;
  min-width: 10px;
  color: @subtext1;
}

/* ─── LEFT: Arch logo ────────────────────────────────────────── */
#custom-arch {
  padding: 4px 10px;
  opacity: 0.95;
  color: @mauve;
}

/* ─── LEFT: Clock ────────────────────────────────────────────── */
#clock {
  color: @lavender;
}

/* ─── LEFT: Media pill ───────────────────────────────────────── */
#custom-media {
  color: @teal;
  transition:
    background-color 0.5s ease,
    color 0.4s ease,
    opacity 0.3s ease;
}

#custom-media.stopped {
  opacity: 0;
  min-width: 0;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
}

#custom-media.paused {
  opacity: 0.5;
  color: @overlay1;
}

#custom-media.playing {
  opacity: 1;
  color: @teal;
}

/* ─── CENTER: Workspaces ─────────────────────────────────────── */
#workspaces {
  padding: 4px 3px;
  border-radius: 14px;
  background-color: alpha(@crust, 0.85);
}

#workspaces button {
  all: initial;
  font-weight: bold;
  color: @overlay1;
  background: transparent;
  padding: 0 7px;
  margin: 0 2px;
  border-radius: 7px;
  transition: all 0.15s ease;
}

/* Active: larger pill-within-pill */
#workspaces button.active {
  color: @mauve;
  background: alpha(@surface0, 0.8);
  padding: 0 16px;
  font-size: 13px;
  border-radius: 12px;
}

#workspaces button:hover {
  background: alpha(@surface1, 0.6);
  color: @subtext1;
}

/* ─── RIGHT: Battery ─────────────────────────────────────────── */
#battery {
  color: @green;
}

#battery.warning {
  color: @peach;
}

#battery.critical {
  color: @red;
}

/* ─── Audio ──────────────────────────────────────────────────── */
#pulseaudio {
  font-size: 18px;
  color: @sapphire;
}

#pulseaudio.muted {
  color: @overlay0;
}

/* ─── Network ────────────────────────────────────────────────── */
#network {
  color: @sky;
}

#network.disconnected {
  color: @maroon;
}

/* ─── Tray ───────────────────────────────────────────────────── */
#tray {
  color: @subtext0;
}
